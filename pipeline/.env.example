# Local runs of the pipeline scripts (`npx tsx src/editor.ts`).
# In production these come from GitHub Actions secrets — see SETUP.md.

# Model access: headless Claude Code on SUBSCRIPTION auth (Claude Max) — never
# metered API billing. Locally nothing is needed here (the logged-in `claude`
# CLI is used). CI uses a CLAUDE_CODE_OAUTH_TOKEN secret from `claude setup-token`.
# CLAUDE_MODEL=opus   # optional override (falls back to sonnet when unavailable)

# Telegram bot token from @BotFather + your numeric user id (from @userinfobot).
# Outbound notifications only — the pipeline never receives Telegram input.
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# Optional: base URL used in Telegram links (defaults handled in code)
# SITE_URL=https://vertical-agent-solutions.pages.dev

# Set to 1 to run the daily editor without pushing or sending Telegram
# EDITOR_DRY_RUN=1

# The contact-form Pages Function additionally needs (set in the Pages project):
#   TELEGRAM_BOT_TOKEN, TELEGRAM_OWNER_ID,
#   TURNSTILE_SECRET_KEY, PUBLIC_TURNSTILE_SITE_KEY (build-time)
#   + a KV namespace binding named INBOX_KV (contact-form rate limiting)
