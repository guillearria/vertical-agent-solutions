# Local runs of the pipeline scripts (`npx tsx src/editor.ts`, `src/runDraft.ts`).
# In production these come from GitHub Actions secrets — see SETUP.md.

# Anthropic API key (drafting + editor decisions)
# Get one at https://console.anthropic.com → API keys
ANTHROPIC_API_KEY=

# Telegram bot token from @BotFather + your numeric user id (from @userinfobot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# Cloudflare KV REST access (fragments, undo tokens)
CF_ACCOUNT_ID=
CF_KV_NAMESPACE_ID=
CF_API_TOKEN=

# Optional: base URL used in Telegram links (defaults handled in code)
# SITE_URL=https://vertical-agent-solutions.pages.dev

# Set to 1 to run the daily editor without pushing, writing KV, or sending Telegram
# EDITOR_DRY_RUN=1

# The Cloudflare Pages Function additionally needs (set in the Pages project):
#   TELEGRAM_BOT_TOKEN, TELEGRAM_OWNER_ID, TELEGRAM_SECRET_TOKEN,
#   GITHUB_REPO, GITHUB_DISPATCH_TOKEN, GITHUB_BRANCH (opt), SITE_URL (opt),
#   TURNSTILE_SECRET_KEY, PUBLIC_TURNSTILE_SITE_KEY (build-time)
#   + a KV namespace binding named INBOX_KV
