# ── Local CLI (pipeline/bot.ts long-polling + draft.ts) ──────────────────────
# Telegram bot token from @BotFather (required)
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram user id — locks the bot to only you.
# Leave blank to allow anyone (not recommended). Get it from @userinfobot.
TELEGRAM_OWNER_ID=

# Anthropic API key for the draft writer (required for `npm run draft`)
# Get one at https://console.anthropic.com → API keys
ANTHROPIC_API_KEY=

# Optional: override where fragments / drafts are saved locally
# INBOX_DIR=
# DRAFTS_DIR=

# ── Hosted pipeline (NOT local — set these as GitHub Actions secrets) ─────────
# See SETUP.md. The drafting Action also needs Cloudflare KV REST access:
#   ANTHROPIC_API_KEY, TELEGRAM_BOT_TOKEN, TELEGRAM_OWNER_ID,
#   CF_ACCOUNT_ID, CF_KV_NAMESPACE_ID, CF_API_TOKEN
# The Cloudflare Pages Function needs (set in the Pages project, see SETUP.md):
#   TELEGRAM_BOT_TOKEN, TELEGRAM_OWNER_ID, TELEGRAM_SECRET_TOKEN,
#   GITHUB_REPO, GITHUB_DISPATCH_TOKEN, GITHUB_BRANCH (opt), SITE_URL (opt)
#   + a KV namespace binding named INBOX_KV
