---
import Layout from '../layouts/BlogPost.astro';

// Set in the Cloudflare Pages build environment; the widget (and its script)
// is omitted when absent so the form still works before Turnstile is set up.
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<Layout
	title="About & Work With Us"
	description="Who is behind Vertical Agent Solutions, and how to get help building agentic systems."
	pubDate={new Date('June 20 2026')}
	isArticle={false}
>
	<p>
		<strong>Vertical Agent Solutions</strong> exists to make the agentic wave legible to people who
		run real businesses — not just the engineers building the tools. The promise is simple: take what
		is genuinely useful about AI agents, strip away the noise, and explain it clearly enough to act
		on.
	</p>

	<h2>What we publish</h2>
	<p>
		Short, deeply-verified guides on adopting AI agents across industries. Every post goes through a
		review loop — fact-checked against real sources, simplified for a non-technical reader, and
		checked against everything we've already published so we never waste your time repeating
		ourselves.
	</p>

	<h2>Work with us</h2>
	<p>
		Reading is the start. If your team wants to actually deploy agentic systems — to automate the
		repetitive, augment the skilled, and move faster than competitors still doing it by hand — that's
		what we build.
	</p>
	<p>
		Tell us where you're stuck and we'll tell you whether agents are the right tool — honestly,
		including when they're not.
	</p>

	<form id="contact-form" method="POST" action="/api/contact">
		<label>
			Your name
			<input type="text" name="name" required maxlength="100" autocomplete="name" />
		</label>
		<label>
			Email
			<input type="email" name="email" required maxlength="200" autocomplete="email" />
		</label>
		<label>
			What are you trying to automate?
			<textarea name="message" required minlength="10" maxlength="2000" rows="6"></textarea>
		</label>
		<p class="hp-field" aria-hidden="true">
			<label>Company <input type="text" name="company" tabindex="-1" autocomplete="off" /></label>
		</p>
		{turnstileSiteKey && <div class="cf-turnstile" data-sitekey={turnstileSiteKey} />}
		<button type="submit">Send message</button>
		<p class="form-status" hidden></p>
	</form>
	<p id="contact-thanks" hidden>
		<strong>Thanks — your message is on its way.</strong> We read everything and reply by email.
	</p>

	{
		turnstileSiteKey && (
			<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer />
		)
	}
	<script is:inline>
		(() => {
			const form = document.getElementById('contact-form');
			const thanks = document.getElementById('contact-thanks');
			if (!form || !thanks) return;
			const status = form.querySelector('.form-status');
			const params = new URLSearchParams(location.search);
			if (params.get('sent') === '1') {
				form.hidden = true;
				thanks.hidden = false;
				return;
			}
			if (params.get('error')) {
				status.textContent = params.get('error');
				status.hidden = false;
			}
			form.addEventListener('submit', async (e) => {
				e.preventDefault();
				const button = form.querySelector('button');
				button.disabled = true;
				status.hidden = true;
				try {
					const res = await fetch(form.action, {
						method: 'POST',
						body: new FormData(form),
						headers: { Accept: 'application/json' },
					});
					const data = await res.json().catch(() => ({}));
					if (res.ok && data.ok) {
						form.hidden = true;
						thanks.hidden = false;
						return;
					}
					status.textContent = data.error || 'Something went wrong — please try again.';
				} catch {
					status.textContent = 'Network error — please try again.';
				}
				status.hidden = false;
				button.disabled = false;
				if (window.turnstile) window.turnstile.reset();
			});
		})();
	</script>

	<style>
		#contact-form {
			display: flex;
			flex-direction: column;
			gap: 1em;
			margin-top: 1.5em;
		}
		#contact-form label {
			display: flex;
			flex-direction: column;
			gap: 0.3em;
			font-weight: bold;
		}
		#contact-form input,
		#contact-form textarea {
			font: inherit;
			font-weight: normal;
			padding: 0.5em;
			border: 1px solid rgb(var(--gray-light));
			border-radius: 6px;
		}
		#contact-form button {
			align-self: flex-start;
			font: inherit;
			padding: 0.5em 1.2em;
			border: none;
			border-radius: 6px;
			background: var(--accent);
			color: white;
			cursor: pointer;
		}
		#contact-form button:disabled {
			opacity: 0.6;
			cursor: wait;
		}
		.form-status {
			color: #b00020;
			margin: 0;
		}
		/* Honeypot: moved off-screen (not display:none — some bots skip that). */
		.hp-field {
			position: absolute;
			left: -9999px;
			width: 1px;
			height: 1px;
			overflow: hidden;
		}
	</style>
</Layout>
