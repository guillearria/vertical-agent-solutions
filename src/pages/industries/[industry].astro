---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import CtaBand from '../../components/CtaBand.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostCard from '../../components/PostCard.astro';
import { SITE_TITLE } from '../../consts';
import { industries, type Industry } from '../../data/industries';

export async function getStaticPaths() {
	const active = (await getCollection('blog')).filter((p) => !p.data.archived);
	return Object.entries(industries)
		.filter(([slug]) => active.some((p) => p.data.industry === slug))
		.map(([slug, industry]) => ({
			params: { industry: slug },
			props: {
				slug,
				industry,
				posts: active
					.filter((p) => p.data.industry === slug)
					.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
			},
		}));
}

interface Props {
	slug: string;
	industry: Industry;
	posts: CollectionEntry<'blog'>[];
}

const { slug, industry, posts } = Astro.props;
const title = `AI Agents for ${industry.name}`;
// Meta description: the blurb's first sentence.
const description = industry.blurb.split(/(?<=\.)\s/)[0];

const jsonLd = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'CollectionPage',
			name: title,
			description,
			url: new URL(Astro.url.pathname, Astro.site).toString(),
		},
		{
			'@type': 'BreadcrumbList',
			itemListElement: [
				{ '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).toString() },
				{
					'@type': 'ListItem',
					position: 2,
					name: 'Industries',
					item: new URL('/industries/', Astro.site).toString(),
				},
				{ '@type': 'ListItem', position: 3, name: industry.name },
			],
		},
	],
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`${title} — ${SITE_TITLE}`}
			description={description}
			image={`/og/industries/${slug}.png`}
			imageAlt={title}
		/>
		<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
		<style>
			.blurb {
				font-size: 1.125rem;
				color: var(--text-secondary);
				margin: 0 0 var(--space-xl);
			}
			ul {
				list-style: none;
				margin: 0 0 var(--space-xl);
				padding: 0;
			}
			ul li {
				padding: var(--space-lg) 0;
				border-bottom: 1px solid var(--border);
			}
			ul li:first-child {
				padding-top: 0;
			}
			ul li:last-child {
				border-bottom: none;
			}
			.back {
				display: inline-block;
				margin-bottom: var(--space-md);
				font-size: 0.875rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<a class="back" href="/industries/">← All industries</a>
			<h1>{title}</h1>
			<p class="blurb">{industry.blurb}</p>
			<ul>
				{
					posts.map((post) => (
						<li>
							<PostCard post={post} hideLabel />
						</li>
					))
				}
			</ul>
			<CtaBand />
		</main>
		<Footer />
	</body>
</html>
