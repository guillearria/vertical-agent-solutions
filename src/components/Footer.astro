---
import { AUTHOR_NAME, AUTHOR_URL } from '../consts';

const today = new Date();
---

<footer>
	&copy; {today.getFullYear()} Vertical Agent Solutions. All rights reserved.
	<div class="footer-links">
		<a href="/about/">About</a>
		<a href="/how-this-site-writes-itself/">How this site writes itself</a>
		<a href="/rss.xml">RSS</a>
	</div>
	<div class="footer-built-by">
		Built by <a href={AUTHOR_URL}>{AUTHOR_NAME}</a>
		{/* TODO: add LinkedIn URL once live — see hq/jobs/applications/linkedin-profile.md */}
	</div>
</footer>
<style>
	footer {
		padding: 2em 1em;
		margin-top: auto;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
		font-size: 0.9em;
	}
	.footer-links {
		display: flex;
		justify-content: center;
		gap: 1.5em;
		margin-top: 0.75em;
	}
	.footer-links a {
		text-decoration: none;
		color: rgb(var(--gray));
	}
	.footer-links a:hover {
		color: rgb(var(--gray-dark));
	}
	.footer-built-by {
		margin-top: 0.75em;
		font-size: 0.9em;
	}
	.footer-built-by a {
		color: rgb(var(--gray));
	}
	.footer-built-by a:hover {
		color: rgb(var(--gray-dark));
	}
</style>
