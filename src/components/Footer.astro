---
import { AUTHOR_NAME, AUTHOR_URL, SITE_TITLE } from '../consts';
import Logo from './Logo.astro';

const today = new Date();
---

<footer>
	<div class="inner">
		<p class="mission">
			<Logo size={20} />
			<span>Plain-English guides to putting AI agents to work in your business.</span>
		</p>
		<nav class="footer-links" aria-label="Footer">
			<a href="/blog/">Guides</a>
			<a href="/about/">About</a>
			<a href="/contact/">Contact</a>
			<a href="/how-this-site-writes-itself/">How this site writes itself</a>
			<a href="/rss.xml">RSS</a>
		</nav>
		<p class="fine">
			&copy; {today.getFullYear()} {SITE_TITLE} · Built and reviewed by
			<a href={AUTHOR_URL}>{AUTHOR_NAME}</a>
			{/* TODO: add LinkedIn URL once live — see hq/jobs/applications/linkedin-profile.md */}
		</p>
	</div>
</footer>

<style>
	footer {
		margin-top: auto;
		background: var(--bg-raised);
		border-top: 1px solid var(--border);
		color: var(--text-secondary);
		font-size: 0.9375rem;
	}
	.inner {
		max-width: var(--container-wide);
		margin: 0 auto;
		padding: var(--space-xl) var(--space-md);
		text-align: center;
	}
	.mission {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: var(--space-xs);
		margin: 0 0 var(--space-md);
	}
	.mission :global(svg) {
		flex-shrink: 0;
	}
	.footer-links {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: var(--space-md) var(--space-lg);
		margin-bottom: var(--space-md);
	}
	.footer-links a {
		color: var(--text-secondary);
		text-decoration: none;
	}
	.footer-links a:hover {
		color: var(--text);
	}
	.fine {
		margin: 0;
		font-size: 0.875rem;
		color: var(--text-faint);
	}
	.fine a {
		color: var(--text-faint);
	}
	.fine a:hover {
		color: var(--text);
	}
</style>
