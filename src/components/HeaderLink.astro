---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;

// Compare with trailing slashes stripped so `/blog/` matches `/blog`, and
// treat section roots as active on their subpages (`/blog/` on `/blog/post/`).
const strip = (p: string) => (p.length > 1 ? p.replace(/\/+$/, '') : p);
const current = strip(Astro.url.pathname);
const target = strip(String(href ?? ''));
const isActive = target === current || (target !== '/' && current.startsWith(target + '/'));
---

<a href={href} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>
<style>
	a {
		display: inline-block;
		text-decoration: none;
	}
	a.active {
		text-decoration: underline;
		text-decoration-color: var(--accent);
		text-decoration-thickness: 2px;
		text-underline-offset: 6px;
	}
</style>
