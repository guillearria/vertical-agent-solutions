---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog/">Blog</HeaderLink>
		</div>
		<div class="cta-link">
			<a href="/about/">Work with us</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
	}
	nav a {
		padding: 1em 0.5em;
		color: rgb(var(--black));
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.cta-link a {
		padding: 0.5em 0.9em;
		border-radius: 6px;
		border-bottom: none;
		background: var(--accent);
		color: white;
		font-size: 0.9em;
	}
	.cta-link a:hover {
		opacity: 0.9;
	}
	@media (max-width: 720px) {
		nav {
			justify-content: center;
			column-gap: 0.5em;
		}
		h2 {
			width: 100%;
			padding-top: 0.75em;
			text-align: center;
		}
		h2 a {
			padding: 0;
		}
		.internal-links {
			display: flex;
			gap: 0.25em;
		}
		nav a {
			padding: 0.6em 0.5em;
		}
		.cta-link a {
			font-size: 0.85em;
			padding: 0.45em 0.9em;
		}
	}
</style>
