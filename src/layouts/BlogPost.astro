---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import CtaBand from '../components/CtaBand.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import PostCard from '../components/PostCard.astro';
import Sources from '../components/Sources.astro';
import { AUTHOR_NAME, AUTHOR_URL } from '../consts';

// isArticle=false lets non-post pages (e.g. /about) reuse this layout without
// getting article metadata / BlogPosting structured data.
type Props = CollectionEntry<'blog'>['data'] & {
	isArticle?: boolean;
	readingMinutes?: number;
	related?: CollectionEntry<'blog'>[];
	/** Post id, used to point social cards at the generated /og/<id>.png. */
	postId?: string;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	sources,
	isArticle = true,
	readingMinutes,
	related = [],
	postId,
} = Astro.props;

const socialImage = heroImage ?? (postId ? `/og/${postId}.png` : undefined);

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const blogPostingLd = isArticle && {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	description,
	datePublished: pubDate.toISOString(),
	dateModified: (updatedDate ?? pubDate).toISOString(),
	url: canonicalURL.toString(),
	mainEntityOfPage: canonicalURL.toString(),
	image: new URL(
		typeof socialImage === 'string' ? socialImage : (socialImage?.src ?? '/og/default.png'),
		Astro.site,
	).toString(),
	// Author stays the Organization: posts are machine-written by the autonomous
	// editor, so claiming personal authorship would be dishonest. The human shows
	// up where he belongs — as the publisher's founder.
	author: { '@type': 'Organization', name: 'Vertical Agent Solutions', url: Astro.site?.toString() },
	publisher: {
		'@type': 'Organization',
		name: 'Vertical Agent Solutions',
		url: Astro.site?.toString(),
		founder: { '@type': 'Person', name: AUTHOR_NAME, url: AUTHOR_URL, sameAs: [AUTHOR_URL] },
	},
};
const breadcrumbLd = isArticle && {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).toString() },
		{ '@type': 'ListItem', position: 2, name: 'Guides', item: new URL('/blog/', Astro.site).toString() },
		{ '@type': 'ListItem', position: 3, name: title },
	],
};
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={socialImage}
			imageAlt={title}
			type={isArticle ? 'article' : 'website'}
			pubDate={pubDate}
			updatedDate={updatedDate}
		/>
		{blogPostingLd && (
			<script is:inline type="application/ld+json" set:html={JSON.stringify(blogPostingLd)} />
		)}
		{breadcrumbLd && (
			<script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
		)}
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0 auto;
				padding: var(--space-2xl) 0 var(--space-3xl);
			}
			.hero-image {
				max-width: var(--container-text);
				margin: 0 auto var(--space-lg);
				padding: 0 var(--space-md);
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: var(--radius-md);
			}
			.prose {
				width: 100%;
				margin: 0 auto;
				padding: 0 var(--space-md);
			}
			.title {
				margin-bottom: var(--space-xl);
			}
			.title h1 {
				margin: 0 0 var(--space-sm);
			}
			.meta {
				margin: 0 0 var(--space-xs);
				font-size: 0.875rem;
				color: var(--text-secondary);
			}
			.byline {
				margin: 0;
				font-size: 0.875rem;
				color: var(--text-faint);
			}
			.byline a {
				color: var(--text-faint);
				text-decoration: underline;
				text-underline-offset: 3px;
			}
			.byline a:hover {
				color: var(--text-secondary);
			}
			.keep-reading {
				max-width: 68ch;
				margin: var(--space-xl) auto 0;
				padding-top: var(--space-lg);
				border-top: 1px solid var(--border);
			}
			.keep-reading h2 {
				margin: 0 0 var(--space-lg);
				font-size: 1.3125rem;
			}
			.keep-reading ul {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: var(--space-lg);
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						{
							isArticle && (
								<p class="meta">
									<FormattedDate date={pubDate} />
									{readingMinutes && <> · {readingMinutes} min read</>}
									{updatedDate && (
										<>
											{' '}
											· Updated <FormattedDate date={updatedDate} />
										</>
									)}
								</p>
							)
						}
						<h1>{title}</h1>
						{
							isArticle && (
								<p class="byline">
									Published by the <a href="/how-this-site-writes-itself/">autonomous editor</a> ·
									reviewed by <a href={AUTHOR_URL}>{AUTHOR_NAME}</a>
								</p>
							)
						}
					</div>
					<slot />
					{isArticle && <Sources sources={sources} />}
					{isArticle && <CtaBand />}
					{
						isArticle && related.length > 0 && (
							<section class="keep-reading">
								<h2>Keep reading</h2>
								<ul>
									{related.map((p) => (
										<li>
											<PostCard post={p} />
										</li>
									))}
								</ul>
							</section>
						)
					}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
